# Порт сервера
PORT=3001

# База данных PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/sosaland

# JWT секрет (любая случайная строка, минимум 32 символа)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ---------------------------------------------------------------------------
# TimeWeb Object Storage (S3-совместимое хранилище)
# Если не заданы — файлы сохраняются локально в backend/uploads/ (только для разработки)
# ---------------------------------------------------------------------------

# Ключи доступа из панели TimeWeb → Object Storage → Ключи доступа
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Название бакета (создать в панели TimeWeb → Object Storage)
S3_BUCKET=your-bucket-name

# Эндпоинт S3 (для TimeWeb — оставить как есть)
S3_ENDPOINT=https://s3.timeweb.cloud

# Регион (для TimeWeb — оставить как есть)
S3_REGION=ru-1

# Публичный базовый URL для доступа к файлам.
# Для TimeWeb формат: https://<bucket-name>.s3.timeweb.cloud
# Если не задан — генерируется автоматически из S3_BUCKET + S3_ENDPOINT
# S3_PUBLIC_URL=https://your-bucket-name.s3.timeweb.cloud
